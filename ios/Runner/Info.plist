<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Apex Run</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>apex_run</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.apexrun.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>apexrun</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>google-sign-in</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<!-- Reversed Web Client ID for Google Sign-In -->
				<string>com.googleusercontent.apps.8211368554-j0apr7p6i3s6adtauhs4ogps8v288ii4</string>
			</array>
		</dict>
	</array>
	<!-- Location permissions -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ApexRun needs your location to track your running route and calculate pace, distance, and elevation.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ApexRun needs background location access to keep tracking your run when the screen is off or another app is open.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>ApexRun needs background location access to keep tracking your run when the screen is off.</string>
	<!-- Camera permission (MediaPipe pose / form analysis) -->
	<key>NSCameraUsageDescription</key>
	<string>ApexRun uses the camera to analyze your running form and gait. Frames are processed on-device and never uploaded.</string>
	<!-- Motion / pedometer -->
	<key>NSMotionUsageDescription</key>
	<string>ApexRun reads device motion data to count your steps and detect running cadence.</string>
	<!-- Health (HRV, sleep, heart rate via HealthKit) -->
	<key>NSHealthShareUsageDescription</key>
	<string>ApexRun reads heart rate, HRV, and sleep data from Apple Health to personalize your training and recovery recommendations.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>ApexRun writes workout summaries to Apple Health so your activity stays synced across the fitness ecosystem.</string>
	<!-- Photo library (avatar upload + activity sharing) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ApexRun saves your generated activity highlight images to your photo library when you tap Save.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>ApexRun saves your generated activity highlight images to your photo library when you tap Save.</string>
	<!-- Speech / TTS for audio coach -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>ApexRun uses speech recognition for hands-free coaching interactions during your runs.</string>
	<!-- Background modes: location keeps GPS tracking alive, audio keeps coach announcements running -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
		<string>processing</string>
	</array>
	<!-- Encryption export compliance: no proprietary crypto -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
